# JSON-RPC endpoint for the chain the engine should operate against.
RPC_URL=http://127.0.0.1:8545

# Private key for the wallet configured as BlackboxMarket's operator
# (see BlackboxMarket.setOperator). Never commit a real key here.
OPERATOR_PRIVATE_KEY=

# Address of the deployed BlackboxMarket contract.
MARKET_CONTRACT_ADDRESS=

# Postgres connection string.
DATABASE_URL=postgres://blackbox:blackbox_dev_only@localhost:5432/blackbox

# How long a fixture's markets stay open before they can be resolved.
CLOSING_IN_SECONDS=1800

# How often the engine checks for fixtures to settle or create.
POLL_INTERVAL_MS=15000
